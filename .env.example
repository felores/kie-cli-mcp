# Kie.ai MCP Server Configuration

# ─────────────────────────────────────────────────────────────────────────
# TRANSPORT (local stdio vs. remote HTTP)
# ─────────────────────────────────────────────────────────────────────────
# stdio (default) — local use via Claude Desktop / Cursor / npx. No network.
# http            — remote Streamable HTTP server (for self-hosting, Coolify).
MCP_TRANSPORT=stdio

# --- The following only apply when MCP_TRANSPORT=http ---------------------

# Port + bind host for the HTTP server (0.0.0.0 = reachable in containers)
PORT=3000
HOST=0.0.0.0

# STRONGLY RECOMMENDED when exposed publicly: a secret bearer token.
# Clients must then send `Authorization: Bearer <token>`. Without it the
# endpoint is OPEN and anyone with the URL can spend your Kie.ai credits.
# Generate one with:  openssl rand -hex 32
MCP_AUTH_TOKEN=

# Path of the MCP endpoint (default /mcp)
MCP_HTTP_PATH=/mcp

# CORS origin for browser-based clients (e.g. claude.ai). "*" = allow all.
MCP_CORS_ORIGIN=*

# ─────────────────────────────────────────────────────────────────────────
# KIE.AI API
# ─────────────────────────────────────────────────────────────────────────
# Required: Your Kie.ai API key (get from https://kie.ai/api-key)
KIE_AI_API_KEY=your-api-key-here

# Optional: API base URL (default shown)
KIE_AI_BASE_URL=https://api.kie.ai/api/v1

# Optional: Request timeout in milliseconds (default: 60 seconds)
KIE_AI_TIMEOUT=60000

# Optional: SQLite database path (default: ~/.kie-ai/tasks.db).
# In Docker/Coolify point this at a mounted volume so task history survives
# redeploys, e.g. /data/tasks.db
KIE_AI_DB_PATH=./tasks.db
# Optional: Callback URL for task completion notifications
# If set, this will be used as default callback URL for all video generation tasks
KIE_AI_CALLBACK_URL=https://your-domain.com/api/callback

# Optional: Tool Filtering (v2.0.2+)
# Enable only specific tools (whitelist, highest priority)
# KIE_AI_ENABLED_TOOLS=nano_banana_image,veo3_generate_video,suno_generate_music

# Enable tools by category (category filter, medium priority)
# Available categories: image, video, audio, utility
# KIE_AI_TOOL_CATEGORIES=image,video

# Disable specific tools (blacklist, lowest priority)
# KIE_AI_DISABLED_TOOLS=midjourney_generate,runway_aleph_video
