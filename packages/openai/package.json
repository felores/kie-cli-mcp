{
  "name": "@felores/kie-ai-openai-server",
  "version": "0.1.1",
  "description": "OpenAI-compatible HTTP transport for selected Kie.ai image and video models.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "kie-ai-openai-server": "dist/bin.js"
  },
  "scripts": {
    "build": "npm run build -w @felores/kie-ai-core && tsc -p tsconfig.json --emitDeclarationOnly && node build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "prepack": "npm run test"
  },
  "keywords": [
    "kie.ai",
    "openai",
    "image-generation",
    "video-generation"
  ],
  "author": "felores",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felores/kie-cli-mcp.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@types/express": "^4.17.21",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@felores/kie-ai-core": "*",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
